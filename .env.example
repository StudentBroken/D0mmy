# D0mmy — API Keys & Configuration
# Copy this file to .env and fill in your values.
# Run `python scripts/setup_keys.py` for an interactive setup.
# All AI calls (generation + embeddings) go through a single Google AI API key.

# ── Google AI API (Gemini + Gemma + Embeddings) ───────────────────────────────
GOOGLE_API_KEY=

# ── Model IDs (Google AI API — aistudio.google.com) ──────────────────────────
# Heavy synthesis — Gemini 3.1 Pro
HEAVY_MODEL=gemini-3.1-pro-preview
# Worker agents — Gemma 4 31B
WORKER_MODEL=gemma-4-31b-it
# Daemons — Gemma 4 26B MoE (~4B active params, fast)
DAEMON_MODEL=gemma-4-26b-a4b-it
# Embeddings
EMBEDDING_MODEL=gemini-embedding-001

# ── FastAPI Server ─────────────────────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
