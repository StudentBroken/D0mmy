{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebSocketMessage",
  "type": "object",
  "required": ["type", "payload", "session_id", "timestamp"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["intent", "sprint_approved", "code_diff", "interrupt", "status_update", "harvest", "error", "ack"]
    },
    "payload": { "type": "object" },
    "session_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
