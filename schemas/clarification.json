{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["questions"],
  "properties": {
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["id", "question", "hint"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "hint": { "type": "string" }
        }
      }
    },
    "skip_if": {
      "type": "string",
      "description": "Condition under which questions can be skipped (e.g. intent is obvious)"
    }
  }
}
