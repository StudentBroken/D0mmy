{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RubricReport",
  "type": "object",
  "required": ["feasible", "bom_constraints", "missing_hardware", "score", "verdict"],
  "properties": {
    "feasible": { "type": "boolean" },
    "bom_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component_id", "constraint", "severity"],
        "properties": {
          "component_id": { "type": "string" },
          "constraint": { "type": "string" },
          "severity": { "type": "string", "enum": ["hard", "soft"] }
        }
      }
    },
    "missing_hardware": { "type": "array", "items": { "type": "string" } },
    "interface_requirements": { "type": "array", "items": { "type": "string" } },
    "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "verdict": { "type": "string" }
  }
}
